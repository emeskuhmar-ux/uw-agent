# Required: Get free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key_here

# Optional but recommended: Free tier 1000 searches/month at https://tavily.com
TAVILY_API_KEY=

# Optional: Increases rate limit. Free at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Optional: Email used for polite API requests (Unpaywall requires one)
CONTACT_EMAIL=your_email@example.com

# Model selection (defaults shown)
GEMINI_MODEL=gemini-2.0-flash-exp
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
